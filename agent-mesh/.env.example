# ── Somnia Network ───────────────────────────────────────────────────────────
SOMNIA_RPC_URL=https://api.infra.testnet.somnia.network/
CHAIN_ID=50312

# ── Deployer Wallet ───────────────────────────────────────────────────────────
# Raw 64-char hex private key (no 0x prefix)
PRIVATE_KEY=

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Get yours at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Deployed Contract Addresses ───────────────────────────────────────────────
AGENT_REGISTRY_ADDRESS=0xe72b8E159291E152860A0313E125d3d3c96FeD4e
AGENT_VAULT_ADDRESS=0x77E8b2ab44f5e676F8fB8FBF05FE1b4cbc2f8c60
TASK_MARKET_ADDRESS=0xF1d421e02d92D89f28AFdfAB3223E60644a36eCA

# ── Agent Wallets ─────────────────────────────────────────────────────────────
ORCHESTRATOR_KEY=
RESEARCH_AGENT_KEY=
CODE_AGENT_KEY=
ANALYSIS_AGENT_KEY=
VERIFIER_AGENT_KEY=

# ── AuraGuard Agent Wallets ───────────────────────────────────────────────────
# Each agent needs its own funded wallet (min 0.001 STT for stake + gas)
AUDIT_ORCHESTRATOR_KEY=
SECURITY_AGENT_KEY=
SIMULATION_AGENT_KEY=
SOCIAL_INTEL_AGENT_KEY=

# ── AuraGuard Contract Addresses ──────────────────────────────────────────────
# Set after running: npx hardhat run scripts/deploy_aura_guard.js --network somnia_testnet
RISK_REGISTRY_ADDRESS=
HONEY_TOKEN_ADDRESS=

# ── AuraGuard Dashboard URL Params ────────────────────────────────────────────
# Open dashboard with: dashboard/index.html?rr=<RISK_REGISTRY>&mkt=<TASK_MARKET>
# Or paste addresses into the dashboard config popup

# ── Convenience aliases ───────────────────────────────────────────────────────
REGISTRY_ADDRESS=${AGENT_REGISTRY_ADDRESS}
MARKET_ADDRESS=${TASK_MARKET_ADDRESS}
