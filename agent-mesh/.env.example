# ── Somnia Network ──────────────────────────────────────────────────────────
# Mainnet (SOMI token, Chain ID 5031)
SOMNIA_MAINNET_RPC=https://api.infra.mainnet.somnia.network/
SOMNIA_MAINNET_WS=wss://api.infra.mainnet.somnia.network/ws

# Testnet (STT token, Chain ID 50312)
# Get free STT: https://testnet.somnia.network/  or  https://stakely.io/faucet/somnia-testnet-stt
SOMNIA_TESTNET_RPC=https://api.infra.testnet.somnia.network/
SOMNIA_TESTNET_WS=wss://api.infra.testnet.somnia.network/ws

# Active network (used by agents at runtime)
SOMNIA_RPC_URL=https://api.infra.testnet.somnia.network/
CHAIN_ID=50312

# ── Wallet ───────────────────────────────────────────────────────────────────
# Never commit real keys — use a dedicated deployment wallet
PRIVATE_KEY=your_private_key_here

# ── Contract Addresses (filled after deploy) ─────────────────────────────────
AGENT_REGISTRY_ADDRESS=
AGENT_VAULT_ADDRESS=
TASK_MARKET_ADDRESS=

# ── Claude API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Agent Wallets (each agent needs its own funded wallet) ───────────────────
ORCHESTRATOR_KEY=
RESEARCH_AGENT_KEY=
CODE_AGENT_KEY=
ANALYSIS_AGENT_KEY=
VERIFIER_AGENT_KEY=
